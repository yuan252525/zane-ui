{
  "name": "@zanejs/ui",
  "version": "1.0.3",
  "description": "A light weight web component library",
  "keywords": [
    "zanejs",
    "stenciljs",
    "web components"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:stencil",
    "build:stencil": "stencil build --docs --prod",
    "build:docs-only": "stencil docs",
    "generate": "stencil generate",
    "dev": "concurrently --kill-others \"pnpm run start:watch\"",
    "start:watch": "stencil build --dev --watch --serve --cors",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "clean": "node ./scripts/clean.mjs"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.mjs"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.js",
      "default": "./loader/index.js"
    },
    "./*": "./*"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.x"
  },
  "dependencies": {
    "@ctrl/tinycolor": "^4.2.0",
    "@floating-ui/dom": "^1.7.4",
    "@popperjs/core": "^2.11.8",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@stencil/angular-output-target": "^1.1.1",
    "@stencil/core": "^4.41.1",
    "@stencil/react-output-target": "^1.2.0",
    "@stencil/sass": "^3.2.3",
    "@stencil/store": "^2.2.2",
    "@types/jest": "^30.0.0",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^25.0.7",
    "@zanejs/utils": "^1.0.5",
    "async-validator": "^4.2.5",
    "beautify": "^0.0.8",
    "classnames": "^2.5.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "highlight.js": "^11.11.1",
    "jest": "^30.2.0",
    "jest-cli": "^30.2.0",
    "js-beautify": "^1.15.4",
    "lodash-es": "^4.17.22",
    "marked": "^17.0.1",
    "memoize-one": "^6.0.0",
    "puppeteer": "^24.35.0",
    "rollup-plugin-dotenv": "^0.5.1",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "rxjs": "^7.8.2",
    "sass": "^1.97.2",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@zanejs/icons": "^1.0.2",
    "@zanejs/lint-config": "^1.0.3",
    "husky": "^9.1.7"
  }
}
